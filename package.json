{
  "name": "gm-pi-environment",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Pi environment: shared skills, extensions, prompts, themes, and portable config.",
  "keywords": ["pi-package"],
  "pi": {
    "skills": [
      "./skills",
      "./extensions/matt-workflow-pi-extension/skills"
    ],
    "extensions": [
      "./extensions/*/index.ts"
    ],
    "prompts": ["./prompts"],
    "themes": ["./themes"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
